{
  "$schema": "../../schema/extension.source.schema.json",
  "id": "caption-themes",
  "name": "Caption Themes",
  "version": "1.0.0",
  "author": "Recast",
  "description": "Extra caption looks for overlay and burned-in captions — a neon karaoke pop, a newsroom lower-third, and a minimal line.",
  "kind": "asset-pack",
  "permissions": [],
  "contributes": {
    "captionPresets": [
      {
        "id": "neon",
        "label": "Neon",
        "description": "Cyan caps, thick outline",
        "fontFamily": "'Anton', sans-serif",
        "fontWeight": 700,
        "fontSizePct": 6.5,
        "position": "center",
        "align": "center",
        "offsetPct": 0,
        "color": "#22d3ee",
        "uppercase": true,
        "letterSpacing": 0.02,
        "background": "none",
        "backgroundColor": "#000000",
        "backgroundOpacity": 0,
        "outlineWidth": 8,
        "outlineColor": "#0f172a",
        "maxLines": 2
      },
      {
        "id": "newsroom",
        "label": "Newsroom",
        "description": "Serif lower-third bar",
        "fontFamily": "Georgia, 'Times New Roman', serif",
        "fontWeight": 600,
        "fontSizePct": 4,
        "position": "bottom",
        "align": "left",
        "offsetPct": 7,
        "color": "#ffffff",
        "uppercase": false,
        "letterSpacing": 0,
        "background": "box",
        "backgroundColor": "#0b1f3a",
        "backgroundOpacity": 88,
        "outlineWidth": 0,
        "outlineColor": "#000000",
        "maxLines": 2
      },
      {
        "id": "minimal",
        "label": "Minimal",
        "description": "Thin, no backing",
        "fontFamily": "'Inter', sans-serif",
        "fontWeight": 500,
        "fontSizePct": 3.6,
        "position": "bottom",
        "align": "center",
        "offsetPct": 5,
        "color": "#ffffff",
        "uppercase": false,
        "letterSpacing": 0,
        "background": "soft",
        "backgroundColor": "#000000",
        "backgroundOpacity": 50,
        "outlineWidth": 0,
        "outlineColor": "#000000",
        "maxLines": 2
      }
    ]
  },
  "assets": []
}
