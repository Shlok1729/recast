    "smoothings": [
      { "id": "steady", "label": "Steady", "smoothing": 35, "snapToClicks": true, "snapWindowMs": 70 },
      { "id": "glide", "label": "Glide", "smoothing": 65, "snapToClicks": true, "snapWindowMs": 100 },
      { "id": "locked", "label": "Locked", "smoothing": 100, "snapToClicks": true, "snapWindowMs": 150 }
    ]
  },
  "assets": []
}
