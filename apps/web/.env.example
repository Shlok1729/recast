#  App 
# PUBLIC_* vars are inlined into the browser bundle — never put secrets here.
# Schema lives in src/lib/env/schema.ts (single source of truth).
PUBLIC_APP_URL=http://localhost:4420
PUBLIC_APP_NAME=Recast

NODE_ENV=development
#  Database (Neon / any Postgres) 
# Connection pooling URL recommended (Neon "pooled" URL works fine with
# the `postgres` driver since we set prepare:false in src/lib/db/index.ts).
DATABASE_URL=postgresql://user:password@localhost:5432/recast

#  Better Auth 
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-a-32-byte-random-string
# Public URL the app is served from. In prod, must match the deployed origin.
BETTER_AUTH_URL=http://localhost:4420
# Extra origins better-auth should accept on top of BETTER_AUTH_URL.
# Comma-separated, supports wildcards (e.g. `https://*.vercel.app`).
# recast.li / recast.nexonauts.com / recast-web.vercel.app are baked in —
# only set this if you're adding a NEW host (custom domain, staging, etc.).
TRUSTED_ORIGINS=

#  OAuth providers (optional — leave blank to hide the social buttons) ─────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

#  Polar (billing — Merchant of Record) ─────────────────────────────────
# Use "sandbox" while testing, "production" once Polar org is verified.
POLAR_SERVER=sandbox
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
# Product IDs created in your Polar dashboard (one per plan).
POLAR_PRODUCT_ID_PRO=

#  Email (Resend) — used for magic links and password resets ────────────
# Without RESEND_API_KEY, magic links / reset URLs are logged to stdout so
# you can copy them in local dev. Set both in production.
RESEND_API_KEY=
EMAIL_FROM=Recast <hello@recast.nexonauts.com>

#  Cloudflare R2 (Recast Cloud video storage) ──────────────────────────
# All four required to enable Cloud uploads. Without them the /api/uploads
# endpoints return 503. Create an API token under R2 → "Manage R2 API Tokens"
# with "Object Read & Write" scoped to the single bucket below.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=recast-cloud
# Optional. Custom domain bound to the bucket for public reads (e.g.
# "https://cdn.recast.li"). When unset, the server always issues short-lived
# signed GETs even for `public` shares — slower but works without DNS setup.
R2_PUBLIC_URL=
