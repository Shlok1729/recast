{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "recast-web",
  "main": ".svelte-kit/cloudflare/_worker.js",
  "compatibility_date": "2025-04-06",
  "compatibility_flags": ["nodejs_compat"], // NEW!
  "assets": {
    "binding": "ASSETS",
    "directory": ".svelte-kit/cloudflare"
  },
}